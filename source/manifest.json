{
  "manifest_version": 3,
  "name": "Shuffle Classifier",
  "version": "1.0.0",
  "description": "Classifies and controls YouTube Music shuffles.",

  "icons": {
    "48": "icons/icon.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "shuffle-classifier@manraj",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["https://music.youtube.com/*"],
      "js": ["browser_handel.js"]
    }
  ]
}